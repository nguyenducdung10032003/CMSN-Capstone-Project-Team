### TC01 - Giao việc cho nhân viên khảo sát thành công (Happy Path)
PATCH http://localhost:9004/api/v1/installation-forms/assign/d75e221e-d150-4962-9afb-687062bfbcc8
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "formCode": "80000001010",
  "formNumber": "20240010"
}

> {%
client.test("Status is 200", function() {
  client.assert(response.status === 200);
});
%}

### TC02 - Thiếu trường formCode trong request body
PATCH http://localhost:9004/api/v1/installation-forms/assign/EMP001
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "formNumber": "FNUM-2026-001"
}

> {%
client.test("Status is 400", function() {
  client.assert(response.status === 400);
});
%}


