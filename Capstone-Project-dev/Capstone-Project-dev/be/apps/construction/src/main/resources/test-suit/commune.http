@uri = http://localhost:9004/api/v1/communes
@keycloak=http://localhost:8080/realms/cmsn/protocol/openid-connect
@client_secret=

### get token
POST {{keycloak}}/token
Content-Type: application/x-www-form-urlencoded
Accept: application/json

grant_type=password&
client_id=&
client_secret={{client_secret}}&
username=&
password=&
scope=openid

> {%
  client.global.set("access_token", response.body.access_token);
  client.global.set("refresh_token", response.body.refresh_token);
%}

### C
### Create commune, full of keys
POST {{uri}}
Content-Type: application/json
Authorization: Bearer {{access_token}}
Accept: application/json

{
  "name": "hehe",
  "type": "RURAL_COMMUNE"
}

### Create commune, blank keys
POST {{uri}}
Content-Type: application/json
Authorization: Bearer {{access_token}}
Accept: application/json

{
  "name": "",
  "type": ""
}

### Create commune, not existing type
POST {{uri}}
Content-Type: application/json
Authorization: Bearer {{access_token}}
Accept: application/json

{
  "name": "commune 1",
  "type": "UUHH"
}

### U
### Update commune, blank id
PUT {{uri}}/
Content-Type: application/json
Authorization: Bearer {{access_token}}
Accept: application/json

{
  "name": "hehe",
  "type": "URBAN_WARD"
}

### Update commune, not existing name
PUT {{uri}}/0f1c0a3a-3c3c-4f33-8c24-7a7c0d6a0028
Content-Type: application/json
Authorization: Bearer {{access_token}}
Accept: application/json

{
  "name": "hehe1",
  "type": "URBAN_WARD"
}

### D
### Delete commune, existing name
DELETE {{uri}}/a9405f07-0e16-48f0-8ad2-d381a4702789
Content-Type: application/json
Authorization: Bearer {{access_token}}
Accept: application/json

{
  "name": "hehe",
  "type": "URBAN_WARD"
}

### Delete commune, not existing id
DELETE {{uri}}/a9405f07-0e16-48f0-8ad2-d381a4702780
Content-Type: application/json
Authorization: Bearer {{access_token}}
Accept: application/json
### R
### Get commune by id - existing
GET {{uri}}/a9405f07-0e16-48f0-8ad2-d381a4702789
Content-Type: application/json
Authorization: Bearer {{access_token}}
Accept: application/json

### Get commune by id - not existing
GET {{uri}}/a9405f07-0e16-48f0-8ad2-d381a4702780
Content-Type: application/json
Authorization: Bearer {{access_token}}
Accept: application/json

### L
### List communes - basic pagination
GET {{uri}}?page=0&size=10
Content-Type: application/json
Authorization: Bearer {{access_token}}
Accept: application/json

### List communes - search by name
GET {{uri}}?search=nam&page=0&size=10
Content-Type: application/json
Authorization: Bearer {{access_token}}
Accept: application/json

### List communes - search by name (accent-insensitive)
### Example: create a commune name "Hòa Bình", then search "hoa binh" should match
GET {{uri}}?search=hoa%20binh&page=0&size=10
Content-Type: application/json
Authorization: Bearer {{access_token}}
Accept: application/json

### List communes - filter by type (URBAN_WARD | RURAL_COMMUNE)
GET {{uri}}?type=URBAN_WARD&page=0&size=10&sort=name,asc
Content-Type: application/json
Authorization: Bearer {{access_token}}
Accept: application/json

### List communes - sort by name ascending
GET {{uri}}?page=0&size=10&sort=name,asc
Content-Type: application/json
Authorization: Bearer {{access_token}}
Accept: application/json
