### Variables
@baseUrl = http://localhost:9004/api/v1
@token = {{access_token}}

### TC01 - Giao đơn thi công thành công (Happy Path)
PATCH {{baseUrl}}/construction/eae87df0-7f02-47b9-baa2-ac2bc9ea61fb
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "formCode": "c2eebc99-9c0b-4ef8-bb6d-6bb9bd380a13",
  "formNumber": "FORM-2024-0003",
  "contractId": "adsfasdvaerg"
}

> {%
client.test("Status is 200", function() {
  client.assert(response.status === 200);
});
%}


### TC02 - Giao thi công cho nhân viên sai vai trò (400)
PATCH {{baseUrl}}/construction/EMP-IT-001
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "formCode": "LĐN",
  "formNumber": "2024/001",
  "contractId": "CONT-001"
}

> {%
client.test("Status is 400", function() {
  client.assert(response.status === 400);
});
%}


