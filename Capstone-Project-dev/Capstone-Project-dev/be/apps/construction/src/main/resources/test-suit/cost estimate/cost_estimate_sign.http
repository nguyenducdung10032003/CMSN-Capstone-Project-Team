### Cost Estimate Signing Test Cases
@baseUrl = http://localhost:9004/api/v1/estimates

### TC01 - Gửi yêu cầu ký duyệt dự toán thành công
POST {{baseUrl}}/sign
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "estId": "7a8192a3-6000-4bbb-9ccc-gggggggg0001",
  "surveyStaff": "d75e221e-d150-4962-9afb-687062bfbcc8",
  "plHead": "6e9f757b-6fa1-4aa6-b7cb-a4cf2290eb20",
  "companyLeadership": "67d04cc3-b4b8-44b9-ba41-91a1e477617a"
}

> {%
client.test("Status is 200", function() {
  client.assert(response.status === 200);
});
%}


