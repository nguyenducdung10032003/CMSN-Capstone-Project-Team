### TC01 - Get completed forms without settlement successfully (Default pagination)
GET http://localhost:9004/api/v1/installation-forms/completed-without-settlement
Authorization: Bearer {{access_token}}

> {%
  client.test("Status is 200", function() {
    client.assert(response.status === 200);
  });
  client.test("Check response structure", function() {
    client.assert(response.body.hasOwnProperty("data"), "Response should contain data");
    client.assert(response.body.hasOwnProperty("message"), "Response should contain message");
  });
%}


### TC02 - Get completed forms with custom pagination (page=0, size=10)
GET http://localhost:9004/api/v1/installation-forms/completed-without-settlement?page=0&size=10
Authorization: Bearer {{access_token}}

> {%
  client.test("Status is 200", function() {
    client.assert(response.status === 200);
  });
%}


