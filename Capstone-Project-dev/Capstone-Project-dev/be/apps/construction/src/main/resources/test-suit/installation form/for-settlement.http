### TC10 - Forbidden request (Invalid Role - e.g. SURVEY_STAFF)
# Assuming token for a user with SURVEY_STAFF role which is not in the allowed list
GET http://localhost:9004/api/v1/installation-forms/completed-without-settlement
Authorization: Bearer {{survey_staff_token}}

> {%
  client.test("Status is 403", function() {
    client.assert(response.status === 403);
  });
%}


