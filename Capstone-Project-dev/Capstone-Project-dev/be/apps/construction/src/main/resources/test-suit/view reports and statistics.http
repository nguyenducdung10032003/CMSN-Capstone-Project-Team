> {%
client.test("Status is 200", function() {
  client.assert(response.status === 200);
});
%}


### TC05 - Access denied without IT_STAFF role (Security check)
# Giả sử dùng một token của nhân viên không có quyền IT_STAFF
GET http://localhost:9004/api/v1/installation-forms/estimate/pending
Authorization: Bearer {{staff_token}}

> {%
client.test("Status is 403", function() {
  client.assert(response.status === 403);
});
%}


### TC06 - Access denied without token
GET http://localhost:9004/api/v1/installation-forms/estimate/pending

> {%
client.test("Status is 401", function() {
  client.assert(response.status === 401);
});
%}


