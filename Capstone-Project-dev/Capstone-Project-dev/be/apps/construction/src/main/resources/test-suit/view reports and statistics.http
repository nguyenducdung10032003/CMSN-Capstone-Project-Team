### TC01 - Get pending estimate forms successfully
GET http://localhost:9004/api/v1/installation-forms/estimate/pending?page=0&size=10
Authorization: Bearer {{auth_token}}

> {%
client.test("Status is 200", function() {
  client.assert(response.status === 200);
});
%}


### TC02 - Get pending registration forms successfully
GET http://localhost:9004/api/v1/installation-forms/registration/pending?page=0&size=10
Authorization: Bearer {{auth_token}}

> {%
client.test("Status is 200", function() {
  client.assert(response.status === 200);
