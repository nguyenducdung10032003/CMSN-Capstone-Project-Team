### TC09 - Reviewed forms data structure check
GET http://localhost:9004/api/v1/installation-forms/reviewed
Authorization: Bearer {{auth_token}}

> {%
client.test("Contains approved and rejected lists", function() {
  client.assert(response.body.data.hasOwnProperty('approved'));
  client.assert(response.body.data.hasOwnProperty('rejected'));
});
%}


