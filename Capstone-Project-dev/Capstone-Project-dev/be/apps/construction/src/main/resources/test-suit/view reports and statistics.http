%}


### TC03 - Get reviewed installation forms successfully
GET http://localhost:9004/api/v1/installation-forms/reviewed
Authorization: Bearer {{auth_token}}

> {%
client.test("Status is 200", function() {
  client.assert(response.status === 200);
  client.assert(response.body.data.approved !== undefined);
  client.assert(response.body.data.rejected !== undefined);
});
%}


