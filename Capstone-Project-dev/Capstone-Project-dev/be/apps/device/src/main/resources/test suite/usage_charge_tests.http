@baseUrl = http://localhost:9006/api/v1
@serial = 00000000-0000-0000-0000-A00000000001
@invalidToken = invalid.token.format

### TC01 - Update usage and calculate progressive charge successfully (authenticated)
POST {{baseUrl}}/usage/{{serial}}
Authorization: Bearer {{access_token}}
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="index"

135.00
--WebAppBoundary
Content-Disposition: form-data; name="recordingDate"

2026-03-01
--WebAppBoundary
Content-Disposition: form-data; name="image"; filename="meter-image.jpg"
Content-Type: image/jpeg

mock data
--WebAppBoundary--

> {%
client.test("TC01 - Status is 200", function() {
  client.assert(response.status === 200);
});
%}

