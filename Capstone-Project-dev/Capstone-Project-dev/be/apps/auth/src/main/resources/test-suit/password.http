@keycloak = http://localhost:8080/realms/cmsn/protocol/openid-connect
@client_secret =
@auth_uri = http://localhost:9003/api/v1/auth

### Get token for authentication
POST {{keycloak}}/token
Content-Type: application/x-www-form-urlencoded
Accept: application/json

grant_type=password&
client_id= &
client_secret={{client_secret}}&
username=  &
password=  &
scope=openid

> {%
  client.global.set("access_token", response.body.access_token);
  client.global.set("refresh_token", response.body.refresh_token);
%}

### CHANGE PASSWORD (Authenticated User)


### Send OTP to your email (Step 1)
### NOTE: Check the application CONSOLE LOGS for the OTP code
### (Look for "OTP for ...: XXXXXX")
POST {{auth_uri}}/send-otp
Content-Type: application/json
Accept: application/json

{
  "email": "@gmail.com"
}

### Verify OTP (Step 2) - Check your email for OTP code
POST {{auth_uri}}/verify-otp
Content-Type: application/json
Accept: application/json

{
  "email": "@gmail.com",
  "otp": ""
}

### Reset password with OTP (Step 3) - Set initial password
POST {{auth_uri}}/reset-password
Content-Type: application/json
Accept: application/json

{
  "email": "ndd1032003@gmail.com",
  "otp": "",
  "newPassword": ""
}

### ========================================
### Now you can use Change Password normally
### ========================================


### Change password - Success case
POST {{auth_uri}}/change-password
Authorization: Bearer {{access_token}}
Content-Type: application/json
Accept: application/json

{
  "oldPassword": "",
  "newPassword": "",
  "confirmPassword": ""
}

### Change password - Old password incorrect
POST {{auth_uri}}/change-password
Authorization: Bearer {{access_token}}
Content-Type: application/json
Accept: application/json

{
  "oldPassword": "",
  "newPassword": "",
  "confirmPassword": ""
}

### Change password - New password and confirm password do not match
POST {{auth_uri}}/change-password
Authorization: Bearer {{access_token}}
Content-Type: application/json
Accept: application/json

{
  "oldPassword": "",
  "newPassword": "",
  "confirmPassword": ""
}

### Change password - Missing old password
POST {{auth_uri}}/change-password
Authorization: Bearer {{access_token}}
Content-Type: application/json
Accept: application/json

{
  "oldPassword": "",
  "newPassword": "",
  "confirmPassword": ""
}

### Change password - Invalid new password format
POST {{auth_uri}}/change-password
Authorization: Bearer {{access_token}}
Content-Type: application/json
Accept: application/json

{
  "oldPassword": "",
  "newPassword": "",
  "confirmPassword": ""
}

### Change password - Without authentication token
POST {{auth_uri}}/change-password
Content-Type: application/json
Accept: application/json

{
  "oldPassword": "",
  "newPassword": "",
  "confirmPassword": ""
}

### ========================================
### FORGOT PASSWORD FLOW
### ========================================

### Step 1: Check if email/username exists
POST {{auth_uri}}/check-existence
Content-Type: application/json
Accept: application/json

{
  "value": "@gmail.com"
}

### Step 2: Send OTP to email
POST {{auth_uri}}/send-otp
Content-Type: application/json
Accept: application/json

{
  "email": "@gmail.com"
}

### Step 3: Verify OTP - Success case
POST {{auth_uri}}/verify-otp
Content-Type: application/json
Accept: application/json

{
  "email": "@gmail.com",
  "otp": ""
}

### Step 3: Verify OTP - Invalid OTP
POST {{auth_uri}}/verify-otp
Content-Type: application/json
Accept: application/json

{
  "email": "@gmail.com",
  "otp": ""
}

### Step 4: Reset password with OTP - Success case
POST {{auth_uri}}/reset-password
Content-Type: application/json
Accept: application/json

{
  "email": "@gmail.com",
  "otp": "",
  "newPassword": ""
}

### Step 4: Reset password with OTP - Invalid OTP
POST {{auth_uri}}/reset-password
Content-Type: application/json
Accept: application/json

{
  "email": "user@example.com",
  "otp": "",
  "newPassword": ""
}

### Step 4: Reset password with OTP - Weak password
POST {{auth_uri}}/reset-password
Content-Type: application/json
Accept: application/json

{
  "email": "user@example.com",
  "otp": "",
  "newPassword": ""
}

