  client.assert(response.status === 200);
});
client.test("Danh sách khách hàng trả về rỗng", function() {
  client.assert(response.body.data.content.length === 0);
});
%}


### TC09 - Tìm kiếm với ký tự đặc biệt
GET http://localhost:9005/api/v1/roadmap-customers/RM_001?search=@#$%^&*()
Authorization: Bearer {{token}}

> {%
client.test("Hệ thống xử lý an toàn với ký tự đặc biệt", function() {
  client.assert(response.status === 200 || response.status === 400);
});
%}


