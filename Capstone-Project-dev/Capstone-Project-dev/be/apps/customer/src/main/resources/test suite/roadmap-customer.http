@roadmap_id = 5e6f7081-4000-4eee-9fff-eeeeeeee0002

### TC01 - Lấy danh sách khách hàng của lộ trình hợp lệ (Happy Path)
GET http://localhost:9005/api/v1/roadmap-customers/{{roadmap_id}}
Authorization: Bearer {{access_token}}

> {%
client.test("Trạng thái phản hồi là 200", function() {
  client.assert(response.status === 200);
});
client.test("Dữ liệu trả về đúng định dạng WrapperApiResponse", function() {
  client.assert(response.body.hasOwnProperty("status"));
  client.assert(response.body.hasOwnProperty("data"));
});
%}


