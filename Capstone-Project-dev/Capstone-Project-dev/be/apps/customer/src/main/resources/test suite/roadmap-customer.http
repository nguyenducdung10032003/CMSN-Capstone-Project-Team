### TC18 - SQL Injection attempt trong tham số search
GET http://localhost:9005/api/v1/roadmap-customers/RM_001?search=' OR 1=1 --
Authorization: Bearer {{token}}

> {%
client.test("An toàn trước SQL Injection", function() {
  client.assert(response.status === 200);
  // Không được trả về tất cả khách hàng không thuộc lộ trình
});
%}


### TC19 - SQL Injection attempt trong roadmapId
GET http://localhost:9005/api/v1/roadmap-customers/RM_001'; DROP TABLE customer; --
Authorization: Bearer {{token}}

> {%
client.test("An toàn trước SQL Injection trên Path Variable", function() {
  client.assert(response.status === 400 || response.status === 404 || response.status === 200);
});
%}


### TC20 - Kiểm tra tính Idempotent (Gửi liên tiếp)
GET http://localhost:9005/api/v1/roadmap-customers/RM_001
Authorization: Bearer {{token}}
### Gửi lại...
GET http://localhost:9005/api/v1/roadmap-customers/RM_001
Authorization: Bearer {{token}}

> {%
client.test("Lần thứ hai vẫn thành công rực rỡ với status 200", function() {
  client.assert(response.status === 200);
});
%}
