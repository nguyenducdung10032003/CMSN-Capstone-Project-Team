### TC06 - Phân trang danh sách khách hàng (Trang 0, Kích thước 10)
GET http://localhost:9005/api/v1/roadmap-customers/{{roadmap_id}}?page=0&size=10
Authorization: Bearer {{token}}

> {%
client.test("Trạng thái phản hồi là 200", function() {
  client.assert(response.status === 200);
});
client.test("Số lượng phần tử trong trang không vượt quá kích thước yêu cầu", function() {
  client.assert(response.body.data.content.length <= 10);
});
%}


