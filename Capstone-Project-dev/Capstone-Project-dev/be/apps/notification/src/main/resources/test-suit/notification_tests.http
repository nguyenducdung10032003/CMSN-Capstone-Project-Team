### TC01 - Create individual notification successfully
POST http://localhost:9007/api/v1/notification
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "title": "System Update",
  "message": "The system will be updated at midnight.",
  "link": "/updates/1"
}

> {%
  client.test("Status is 201", function () {
    client.assert(response.status === 201);
  });
%}


