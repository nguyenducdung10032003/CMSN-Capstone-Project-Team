### TC11 - Security - SQL Injection attempt in title
POST http://localhost:9007/api/v1/notification
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "title": "' OR '1'='1' --",
  "message": "Database threat test"
}

> {%
  client.test("Status is 400 or 201", function () {
    client.assert(response.status === 400 || response.status === 201);
  });
%}


### TC12 - Security - XSS Script in message
POST http://localhost:9007/api/v1/notification
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "title": "Alert",
  "message": "<script>alert('XSS')</script>",
  "link": "javascript:void(0)"
}

> {%
  client.test("Status is 400 or 201", function () {
    client.assert(response.status === 400 || response.status === 201);
  });
%}


