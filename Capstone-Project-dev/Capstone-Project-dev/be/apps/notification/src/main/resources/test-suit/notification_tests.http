### TC16 - Create department notification successfully
POST http://localhost:9007/api/v1/notification/departments
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "title": "Department Meeting",
  "message": "General meeting for IT and Finance.",
  "link": "/meeting/it-finance",
  "targetDepartmentCodes": [
    "IT",
    "FINANCE"
  ]
}

> {%
  client.test("Status is 201", function () {
    client.assert(response.status === 201);
  });
%}


